# Application
APP_NAME=second-brain
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8090

# LLM — set LLM_PROVIDER to: openai | nvidia | ollama
LLM_PROVIDER=nvidia
LLM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
LLM_TEMPERATURE=0.2
LLM_ENABLE_THINKING=false
LLM_REASONING_BUDGET=8192

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Local Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.2

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secondbrain_dev

# Redis (M0 working memory)
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=second-brain

# Memory
CONTEXT_TOKEN_BUDGET=8192
RETRIEVAL_TOP_K=8
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Phase 4 — actuation policy
IOT_DRY_RUN=true
REQUIRE_HUMAN_APPROVAL=true
IOT_COMFORT_MIN_C=18.0
IOT_COMFORT_MAX_C=26.0
IOT_MAX_SETPOINT_DELTA=5.0

# Phase 6 — MQTT (optional; pip install "second-brain[mqtt]")
MQTT_ENABLED=false
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TELEMETRY_TOPIC=secondbrain/telemetry/#
MQTT_COMMAND_TOPIC_TEMPLATE=secondbrain/commands/{device_id}

# Observability
OTEL_ENABLED=false
OTEL_SERVICE_NAME=second-brain
